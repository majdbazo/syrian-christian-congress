<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <%- include('../partials/head', { title: 'Register — Syrian Christian Congress', description: 'Register with the Syrian Christian Congress — Join our civic platform.' }) %>
</head>
<body>

<%- include('../partials/nav', { activePage: 'register', scrolled: true }) %>

<!-- ── Page hero ───────────────────────────────────────────────────────── -->
<section class="page-hero">
  <div class="container">
    <h1 data-i18n="register.page_title">Register</h1>
    <p data-i18n="register.page_sub">Join the Syrian Christian Congress and become part of a growing civic movement.</p>
  </div>
</section>

<!-- ── Form ────────────────────────────────────────────────────────────── -->
<section class="section form-section">
  <div class="container">

    <div class="form-card animate-in">

      <!-- Success state -->
      <div class="success-box" id="registerSuccess">
        <div class="success-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h2 class="success-title">Registration Successful!</h2>
        <p class="success-body">Thank you for registering with the Syrian Christian Congress. We will be in touch with you soon.</p>
      </div>

      <!-- Form -->
      <form id="registerForm" novalidate>
        <div class="form-grid">

          <div class="form-group">
            <label class="form-label" for="first_name">
              <span data-i18n="register.first_name">First Name</span>
              <span class="req">*</span>
            </label>
            <input type="text" id="first_name" name="first_name" class="form-input"
                   required autocomplete="given-name"
                   data-i18n-ph="register.first_name">
          </div>

          <div class="form-group">
            <label class="form-label" for="last_name">
              <span data-i18n="register.last_name">Last Name</span>
              <span class="req">*</span>
            </label>
            <input type="text" id="last_name" name="last_name" class="form-input"
                   required autocomplete="family-name"
                   data-i18n-ph="register.last_name">
          </div>

          <div class="form-group full">
            <label class="form-label" for="email">
              <span data-i18n="register.email">Email Address</span>
              <span class="req">*</span>
            </label>
            <input type="email" id="email" name="email" class="form-input"
                   required autocomplete="email"
                   placeholder="you@example.com">
          </div>

          <div class="form-group full">
            <label class="form-label" for="address">
              <span data-i18n="register.address">Address</span>
            </label>
            <input type="text" id="address" name="address" class="form-input"
                   autocomplete="street-address"
                   data-i18n-ph="register.address">
          </div>

          <div class="form-group">
            <label class="form-label" for="country">
              <span data-i18n="register.country">Country</span>
              <span class="req">*</span>
            </label>
            <select id="country" name="country" class="form-select" required>
              <option value="">Select your country</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label" for="state">
              <span data-i18n="register.state">State / Province / Region</span>
              <span class="req">*</span>
            </label>
            <input type="text" id="state" name="state" class="form-input" required
                   data-i18n-ph="register.state">
          </div>

          <div class="form-group full">
            <label class="form-label" for="denomination">
              <span data-i18n="register.denomination">Denomination</span>
            </label>
            <select id="denomination" name="denomination" class="form-select">
              <option value="">Select your denomination</option>
            </select>
          </div>

          <div class="form-group full">
            <label class="form-label" for="about_yourself">
              <span data-i18n="register.about">Tell Us About Yourself</span>
            </label>
            <textarea id="about_yourself" name="about_yourself" class="form-textarea"
                      rows="5"
                      data-i18n-ph="register.about_ph"></textarea>
          </div>

        </div><!-- /form-grid -->

        <div id="formMessage" class="form-message" role="alert" style="display:none"></div>

        <div class="form-submit mt-2">
          <button type="submit" class="btn btn-navy btn-lg" data-i18n="register.submit">
            Submit Registration
          </button>
        </div>
      </form>

    </div><!-- /form-card -->
  </div>
</section>

<%- include('../partials/footer') %>

<script src="/js/translations.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
