<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <%- include('../partials/head', { title: 'Contact — Syrian Christian Congress', description: 'Contact the Syrian Christian Congress.' }) %>
</head>
<body>

<%- include('../partials/nav', { activePage: 'contact', scrolled: true }) %>

<!-- ── Page hero ───────────────────────────────────────────────────────── -->
<section class="page-hero">
  <div class="container">
    <h1 data-i18n="contact.page_title">Contact Us</h1>
    <p data-i18n="contact.page_sub">Get in touch with the Syrian Christian Congress.</p>
  </div>
</section>

<!-- ── Contact content ─────────────────────────────────────────────────── -->
<section class="section form-section">
  <div class="container">
    <div class="contact-layout">

      <!-- Contact form -->
      <div>
        <div class="form-card animate-in" style="max-width:100%">

          <!-- Success state -->
          <div class="success-box" id="contactSuccess">
            <div class="success-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <h2 class="success-title">Message Sent!</h2>
            <p class="success-body">Thank you for contacting us. We will respond as soon as possible.</p>
          </div>

          <form id="contactForm" novalidate>
            <div class="form-grid">

              <div class="form-group full">
                <label class="form-label" for="contact_name">
                  <span data-i18n="contact.name">Full Name</span>
                  <span class="req">*</span>
                </label>
                <input type="text" id="contact_name" name="contact_name" class="form-input"
                       required autocomplete="name"
                       data-i18n-ph="contact.name">
              </div>

              <div class="form-group full">
                <label class="form-label" for="contact_email">
                  <span data-i18n="contact.email">Email Address</span>
                  <span class="req">*</span>
                </label>
                <input type="email" id="contact_email" name="contact_email" class="form-input"
                       required autocomplete="email"
                       placeholder="you@example.com">
              </div>

              <div class="form-group full">
                <label class="form-label" for="contact_subject">
                  <span data-i18n="contact.subject">Subject</span>
                </label>
                <input type="text" id="contact_subject" name="contact_subject" class="form-input"
                       data-i18n-ph="contact.subject">
              </div>

              <div class="form-group full">
                <label class="form-label" for="contact_message">
                  <span data-i18n="contact.message">Message</span>
                  <span class="req">*</span>
                </label>
                <textarea id="contact_message" name="contact_message" class="form-textarea"
                          rows="7" required
                          data-i18n-ph="contact.message_ph"></textarea>
              </div>

            </div>

            <div id="contactMessage" class="form-message" role="alert" style="display:none"></div>

            <div class="form-submit mt-2">
              <button type="submit" class="btn btn-navy btn-lg" data-i18n="contact.submit">
                Send Message
              </button>
            </div>
          </form>

        </div>
      </div>

      <!-- Sidebar -->
      <div class="contact-sidebar">

        <!-- Social -->
        <div class="info-card animate-in">
          <h3 data-i18n="contact.follow_us">Follow Us</h3>
          <div class="social-links">
            <a href="https://www.facebook.com/SyrianChristianCongress"
               target="_blank" rel="noopener" class="social-link social-link-fb">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="white">
                <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/>
              </svg>
              Facebook
            </a>
            <a href="https://x.com/SyrianChristianCongress"
               target="_blank" rel="noopener" class="social-link social-link-x">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="white">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
              X (Twitter)
            </a>
          </div>
        </div>

        <!-- Calendar -->
        <div class="info-card animate-in">
          <h3 data-i18n="contact.cal_title">Subscribe to Our Calendar</h3>
          <p style="font-size:.9rem;color:var(--gray-500);margin-bottom:1rem;line-height:1.7" data-i18n="contact.cal_body">
            Stay updated with all Congress events by subscribing to our calendar.
          </p>
          <button class="btn btn-gold cal-subscribe-btn" style="width:100%;justify-content:center" data-i18n="contact.cal_btn">
            Subscribe
          </button>
        </div>

        <!-- Notice -->
        <div class="info-card animate-in" style="border-left:4px solid var(--gold)">
          <p style="font-size:.875rem;color:var(--gray-500);line-height:1.7">
            The Syrian Christian Congress operates internationally and represents communities
            across Syria and the global diaspora. We welcome all enquiries.
          </p>
        </div>

      </div>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>

<script src="/js/translations.js"></script>
<script src="/js/main.js"></script>
</body>
</html>
