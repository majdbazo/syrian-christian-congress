<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <%- include('../partials/head', { title: 'Our Members — Syrian Christian Congress', description: 'Our Members — The Syrian Christian Congress global membership.', extraCss: ['/css/members.css'] }) %>
</head>
<body>

<%- include('../partials/nav', { activePage: 'members', scrolled: true }) %>

<!-- ── Hero ─────────────────────────────────────────────────────────────── -->
<section class="mem-hero">
  <div class="container mem-hero-content">
    <h1 data-i18n="members.page_title">Our Members</h1>
    <p data-i18n="members.page_sub">A look at the global reach of the Syrian Christian Congress — members from Syria and the diaspora.</p>
  </div>
</section>

<!-- ── Stats & Chart ─────────────────────────────────────────────────────── -->
<section class="section" style="background:var(--off-white)">
  <div class="container">

    <div class="mem-stats-row animate-in" id="memStats" style="display:none">
      <div class="mem-stat-card">
        <div class="mem-stat-val" id="stat-total">0</div>
        <div class="mem-stat-lbl" data-i18n="members.total_label">Total Registered Members</div>
      </div>
      <div class="mem-stat-card">
        <div class="mem-stat-val" id="stat-countries">0</div>
        <div class="mem-stat-lbl" data-i18n="members.countries_label">Countries Represented</div>
      </div>
    </div>

    <div class="mem-loading" id="memLoading">
      <div class="mem-spinner"></div>
    </div>

    <div class="chart-section animate-in" id="chartSection" style="display:none">
      <h2 data-i18n="members.chart_title">Members by Country</h2>
      <div id="countryChart"></div>
    </div>

    <div class="mem-empty animate-in" id="memEmpty" style="display:none">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 00-3-3.87"/>
        <path d="M16 3.13a4 4 0 010 7.75"/>
      </svg>
      <p data-i18n="members.no_data">No member data available yet. Be the first to register.</p>
    </div>

  </div>
</section>

<!-- ── CTA ───────────────────────────────────────────────────────────────── -->
<section class="section">
  <div class="container">
    <div class="mem-cta animate-in">
      <h2 data-i18n="members.cta_title">Join the Congress</h2>
      <p data-i18n="members.cta_body">Register today to be part of the Syrian Christian Congress and add your voice to this growing civic movement.</p>
      <a href="/register.html" class="btn btn-gold btn-lg" data-i18n="members.cta_btn">Register Now</a>
    </div>
  </div>
</section>

<%- include('../partials/footer') %>

<script src="/js/translations.js?v=2"></script>
<script src="/js/main.js"></script>
<script>
(async () => {
  try {
    const res = await fetch('/api/members').then(r => r.json());
    document.getElementById('memLoading').style.display = 'none';

    if (!res.success || !res.total) {
      document.getElementById('memEmpty').style.display = 'block';
      return;
    }

    document.getElementById('memStats').style.display = 'grid';
    document.getElementById('stat-total').textContent = res.total.toLocaleString();
    document.getElementById('stat-countries').textContent = res.byCountry.length;

    document.getElementById('chartSection').style.display = 'block';
    const max = res.byCountry[0].count;
    document.getElementById('countryChart').innerHTML = res.byCountry.map((r, i) => `
      <div class="country-bar">
        <div class="country-name" title="${esc(r.country)}">${esc(r.country)}</div>
        <div class="bar-track">
          <div class="bar-fill${i === 0 ? ' gold' : ''}" style="width:${Math.round((r.count/max)*100)}%"></div>
        </div>
        <div class="country-count">${r.count}</div>
      </div>`).join('');
  } catch {
    document.getElementById('memLoading').style.display = 'none';
    document.getElementById('memEmpty').style.display = 'block';
  }
})();

function esc(s) {
  return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
</script>
</body>
</html>
