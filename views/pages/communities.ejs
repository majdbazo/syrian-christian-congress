<script>
const tradLinks = document.querySelectorAll('.trad-link');
const tradSections = document.querySelectorAll('.tradition-section');
window.addEventListener('scroll', () => {
  let current = '';
  tradSections.forEach(s => { if (window.scrollY >= s.offsetTop - 120) current = s.id; });
  tradLinks.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + current));
});
</script>
